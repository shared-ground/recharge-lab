<section class="wrap reveal">
  <div class="kicker">The Science, Simplified</div>
  <h2>Recover Smarter,<br>Not Harder</h2>
  <p>Pulsed Electromagnetic Field (PEMF) therapy is one of the most effective and underused tools in athletic recovery. Gentle electromagnetic pulses stimulate your cells to produce more energy and repair faster, clearing inflammation and restoring your tank from the inside out.</p>
  <p class="punch">No needles. No pills. No effort. Just your body doing what it's designed to do. Faster.</p>
  <!-- PEMF Explainer Video -->
  <div id="explainer-wrap" class="explainer-wrap">
    <iframe
      id="pemf-explainer"
      src="./The%20Recharge%20Lab%20-%20PEMF%20Explainer.html"
      style="width:100%;aspect-ratio:16/9;border:0;display:block;"
      allow="autoplay; fullscreen"
      allowfullscreen
      title="How PEMF works -- The Recharge Lab explainer"
    ></iframe>

    <!-- Full screen toggle -- always available (CSS overlay, works on iOS too) -->
    <button
      type="button"
      class="explainer-fs"
      aria-label="Play explainer in full screen"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 3H5a2 2 0 0 0-2 2v3M21 8V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3M16 21h3a2 2 0 0 0 2-2v-3"/>
      </svg>
      <span>Full screen</span>
    </button>

    <!-- Close full screen (visible only while expanded) -->
    <button
      type="button"
      class="explainer-close"
      aria-label="Close full screen"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

    <!-- Play overlay -- visible until first click. The click dispatches the
         pointerdown gesture the explainer iframe listens for to unlock audio. -->
    <button
      id="explainer-play-btn"
      type="button"
      aria-label="Play PEMF explainer"
      onclick="
        var f=document.getElementById('pemf-explainer');
        try { f.contentWindow.dispatchEvent(new Event('pointerdown')); } catch(e) {}
        this.style.display='none';
      "
      style="
        position:absolute;
        inset:0;
        width:100%;
        height:100%;
        background:rgba(7,12,22,.55);
        border:none;
        cursor:pointer;
        display:flex;
        align-items:center;
        justify-content:center;
        flex-direction:column;
        gap:12px;
        font-family:'Poppins',sans-serif;
      "
    >
      <!-- Play circle -->
      <span style="
        width:64px;height:64px;border-radius:50%;
        background:linear-gradient(145deg,#2FD3E8,#2E8BE6);
        display:flex;align-items:center;justify-content:center;
        box-shadow:0 0 32px rgba(47,211,232,.35);
        flex-shrink:0;
      ">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
          <polygon points="6,3 20,12 6,21"/>
        </svg>
      </span>
      <span style="
        color:#F2F6FB;
        font-size:.85rem;
        font-weight:500;
        letter-spacing:.08em;
        text-transform:uppercase;
      ">Watch -- How PEMF Works</span>
    </button>
  </div>

  <div class="feats">
    <div class="feat"><div class="big">FDA</div><div class="sm">Cleared Tech</div></div>
    <div class="feat"><div class="big">NASA</div><div class="sm">Researched</div></div>
    <div class="feat"><div class="big">Decades</div><div class="sm">Proven</div></div>
  </div>
</section>

<style>
  /* Explainer breaks out of the 760px text column: wider on desktop,
     full-bleed on mobile so the video is legible. Body has overflow-x:hidden,
     so the 100vw width never introduces a horizontal scrollbar. */
  .explainer-wrap {
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    width: min(100vw, 1000px);
    margin: 0 auto 40px;
    border-radius: 10px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, .08);
  }
  @media (max-width: 560px) {
    .explainer-wrap { border-radius: 0; }
  }

  .explainer-fs {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 13px;
    border-radius: 999px;
    border: 1px solid rgba(47, 179, 230, .5);
    background: rgba(7, 12, 22, .6);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: #F2F6FB;
    cursor: pointer;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .04em;
    text-transform: uppercase;
    transition: .25s;
  }
  .explainer-fs:hover {
    background: rgba(47, 179, 230, .18);
    border-color: var(--cyan);
  }

  /* Close button -- only shown while expanded */
  .explainer-close {
    display: none;
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 3;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    border: 1px solid rgba(47, 179, 230, .5);
    background: rgba(7, 12, 22, .6);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: #F2F6FB;
    cursor: pointer;
    transition: .25s;
  }
  .explainer-close:hover {
    background: rgba(47, 179, 230, .18);
    border-color: var(--cyan);
  }

  /* CSS pseudo-fullscreen: fills the viewport on every device, including iOS
     where the native Fullscreen API is unavailable for non-video elements. */
  .explainer-wrap.fs-active {
    position: fixed;
    inset: 0;
    z-index: 9999;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    max-width: none;
    left: 0;
    transform: none;
    margin: 0;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .explainer-wrap.fs-active iframe {
    max-height: 100vh;
    max-height: 100dvh;
  }
  .explainer-wrap.fs-active .explainer-fs {
    display: none;
  }
  .explainer-wrap.fs-active .explainer-close {
    display: flex;
  }
</style>

<script>
  const wrap = document.getElementById('explainer-wrap');
  if (wrap) {
    const fsBtn = wrap.querySelector<HTMLButtonElement>('.explainer-fs');
    const closeBtn = wrap.querySelector<HTMLButtonElement>('.explainer-close');

    const open = () => {
      wrap.classList.add('fs-active');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      wrap.classList.remove('fs-active');
      document.body.style.overflow = '';
    };

    fsBtn?.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && wrap.classList.contains('fs-active')) close();
    });
  }
</script>
