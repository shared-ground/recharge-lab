---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Science from '../components/Science.astro';
import Formats from '../components/Formats.astro';
import Testimonials from '../components/Testimonials.astro';
import ClosingBand from '../components/ClosingBand.astro';
import Footer from '../components/Footer.astro';
import { pinnedTestimonials, carouselTestimonials } from '../data/testimonials';
---

<Base>
  <Header />
  <main id="top">
    <Hero />
    <Science />
    <Formats />
    <Testimonials pinned={pinnedTestimonials} carousel={carouselTestimonials} />
    <ClosingBand />
  </main>
  <Footer />
</Base>
